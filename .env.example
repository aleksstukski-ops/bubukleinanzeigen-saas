# Copy this to .env and fill in all values before starting

# --- Core ---
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
# Generate FERNET_KEY: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_FERNET_KEY_HERE
DATABASE_URL=postgresql+asyncpg://bubu:bubu_dev@postgres:5432/bubukleinanzeigen
REDIS_URL=redis://redis:6379/0
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALLOWED_ORIGINS=http://localhost:3000,https://bubuanzeigen.de
FRONTEND_URL=https://bubuanzeigen.de

# --- Scraper ---
PLAYWRIGHT_HEADLESS=true
SCRAPER_MAX_CONCURRENT_ACCOUNTS=5
SCRAPER_SESSION_DIR=/app/storage/sessions

# --- SMTP (Gmail App-Passwort) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your@gmail.com
ALERT_EMAIL_TO=your@gmail.com

# --- Telegram Alerts (optional, aber empfohlen) ---
# Bot erstellen via @BotFather, Chat-ID via @userinfobot ermitteln
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- VAPID Web Push ---
# Generieren: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@bubuanzeigen.de

# --- Stripe ---
# Dashboard: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
