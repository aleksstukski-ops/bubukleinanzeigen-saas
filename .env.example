# Copy this to .env and fill in values

SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
DATABASE_URL=postgresql+asyncpg://bubu:bubu_dev@postgres:5432/bubukleinanzeigen
REDIS_URL=redis://redis:6379/0
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
PLAYWRIGHT_HEADLESS=true
SCRAPER_MAX_CONCURRENT_ACCOUNTS=5
SCRAPER_SESSION_DIR=/app/storage/sessions

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=changeme
SMTP_FROM=your@gmail.com

# Stripe — Keys aus dem Stripe Dashboard
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs aus dem Stripe Dashboard (nach Produkte anlegen)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
FRONTEND_URL=https://bubuanzeigen.de
